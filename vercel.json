{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "magazin.pfoten-plan.de" }],
      "destination": "/magazin/:path*"
    }
  ],
  "functions": {
    "app/api/admin/plan-korrektur/route.ts": {
      "maxDuration": 120
    },
    "app/api/mitglieder/plan/generate/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/upsell-cron?secret=pfoten-cron-2024",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/mitglieder/challenges/notify?secret=pfoten-cron-2024",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/process-paid-leads?secret=pfoten-cron-2024",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/process-upsell-modules?secret=pfoten-cron-2024",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/warm-recovery-drip?secret=pfoten-cron-2024",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/email-sequence?secret=pfoten-cron-2024",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/premium-offer?secret=pfoten-cron-2024",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/generate-coaches?secret=pfoten-cron-2024",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/generate-grundkommandos?secret=pfoten-cron-2024",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/warm-recovery-backlog?secret=pfoten-cron-2024",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/club-drip?secret=pfoten-cron-2024",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/pl-nurture?secret=pfoten-cron-2024",
      "schedule": "*/10 * * * *"
    }
  ]
}