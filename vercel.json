{
  "cleanUrls": true,
  "functions": {
    "app/api/admin/plan-korrektur/route.ts": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/upsell-cron?secret=pfoten-cron-2024",
      "schedule": "0 9 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.pfoten-plan.de" }],
      "destination": "https://pfoten-plan.de/:path*",
      "permanent": true
    }
  ]
}